# TG Bot Token
BOT_TOKEN=your_bot_token_here

# 管理员ID列表（逗号分隔）
ADMIN_IDS=123456789

# JavBus API 地址（你自建的 javbus-api 服务地址）
JAVBUS_API_URL=http://your-javbus-api:3000

# API 认证 Token（可选，如果你的 javbus-api 开启了 token 验证）
# JAVBUS_AUTH_TOKEN=your_token_here

# 默认影片类型：normal(有码) / uncensored(无码)
DEFAULT_TYPE=normal

# 磁力链接排序方式：size / date
MAGNET_SORT_BY=size

# 磁力链接排序方向：desc / asc
MAGNET_SORT_ORDER=desc

# 并发请求数
MAX_CONCURRENT=10

# 单次搜索最大页数
MAX_PAGES=20

# 时区
TZ=Asia/Shanghai