BOT_TOKEN=your_bot_token_here
ADMIN_USER_ID=123456789
# 自定义 Telegram API（用于突破文件大小限制）
# TELEGRAM_API_URL=http://127.0.0.1:8081
# 本地视频目录
VIDEO_ROOT=/app/videos
# 数据库路径
DB_PATH=./data/vsender.db
# 发送并发数
SEND_CONCURRENCY=5
# 批次间间隔（秒）
BATCH_INTERVAL=1.0
# 视频间间隔（秒）
VIDEO_INTERVAL=3.0
# 列表每页数量
LIST_PAGE_SIZE=20