# ==================== Bot 配置 ====================
# Telegram Bot Token（从 @BotFather 获取）
BOT_TOKEN=your_commander_bot_token

# 管理员 ID（逗号分隔，可从 @userinfobot 获取）
ADMIN_IDS=123456789

# 工作群组 ID（指挥官 bot 和其他 bot 所在的群组）
# 创建群组后将所有 bot 拉入，然后把群组 ID 填入
# 群组 ID 是负数，如 -1001234567890
WORK_GROUP_ID=-1001234567890

# ==================== LLM 配置 ====================
# LLM API 地址（兼容 OpenAI /v1/chat/completions 格式）
# 支持：OpenAI、DeepSeek、Ollama、vLLM 等
# 示例：
#   OpenAI:    https://api.openai.com/v1
#   DeepSeek:  https://api.deepseek.com/v1
#   Ollama:    http://localhost:11434/v1
LLM_API_URL=https://api.openai.com/v1

# LLM API Key
LLM_API_KEY=sk-your-api-key

# 模型名称
LLM_MODEL=gpt-4o-mini

# ==================== 可选配置 ====================
# LLM 最大 token 数
# LLM_MAX_TOKENS=512
# LLM 温度参数
# LLM_TEMPERATURE=0.3

# ==================== 安全配置 ====================
# 每个 bot 每秒最多发送的消息数
# RATE_LIMIT_PER_BOT=1.0
# 最大交互深度（防止循环）
# MAX_INTERACTION_DEPTH=5
# 等待回复超时（秒）
# RESPONSE_TIMEOUT=30
# 消息去重窗口（秒）
# DEDUP_WINDOW=60
