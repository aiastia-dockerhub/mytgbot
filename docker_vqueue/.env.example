# Bot Token（从 @BotFather 获取）
BOT_TOKEN=your_bot_token_here

# 管理员ID（逗号分隔）
ADMIN_IDS=123456789

# 转发保护（true/false）- 防止接收者转发Bot发送的媒体
PROTECT_CONTENT=true

# 显示来源标注（true/false）
SHOW_SOURCE=true

# 并发发送数（同时发给N个用户）
SEND_CONCURRENCY=10
# 每批发完后间隔（秒）
BATCH_INTERVAL=1.0
# 不同组之间间隔（秒）
VIDEO_INTERVAL=5

# 队列检查间隔（秒）
QUEUE_CHECK_INTERVAL=5

# 24小时活跃度检查间隔（秒）
ACTIVE_CHECK_INTERVAL=3600

# 24小时内最少发送视频数（不足则系统停止）
MIN_VIDEOS_24H=10